@Override
public Map<String, List<JSONObject>> enrichProcessedItem(
        JSONObject entry,
        Map<String, List<JSONObject>> indexDocumentsMap,
        Map<String, String> charsetConversionValue,
        String fileName,
        long integrationId) {
    try {
        dataIndexMapping.forEach(dto -> {
            indexDocumentsMap
                    .computeIfAbsent(dto.getIndexName(), k -> new ArrayList<>())
                    .add(entry);
            entry.put(PROVIDER_DATATYPE, dto.getDataType());
        });
    } catch (Exception e) {
        log.error(ErrorConstants.ENRICHING_PROCESSED_ITEM_FAILED, e);
        fileIntegrationStatusUpdater.updateStatus(INTEGRATION_FAILED, integrationId);
    }
    return indexDocumentsMap;
}
