private String toHistoricalFileName(String onDemandFileName, String historicalDate) {
    int dotIdx = onDemandFileName.lastIndexOf('.');
    String base = (dotIdx > 0) ? onDemandFileName.substring(0, dotIdx) : onDemandFileName;
    String ext  = (dotIdx > 0) ? onDemandFileName.substring(dotIdx) : ".req";

    String historicalBase;
    if (base.endsWith("_U") || base.endsWith("_I")) {
        // Standard U/I pattern: strip suffix, add _H_<date>
        historicalBase = base.substring(0, base.length() - 2) + "_H_" + historicalDate;
    } else if (base.endsWith("_H")) {
        // Template already ends with _H (e.g. DD_INPUT_APEM_H)
        // Just append the date — no double _H_
        historicalBase = base + "_" + historicalDate;
    } else {
        // Defensive fallback
        historicalBase = base + "_H_" + historicalDate;
    }
    return historicalBase + ext;
}

