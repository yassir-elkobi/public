public static final String ON_DEMAND_FILENAME_REGEX =     "MUSE_Sync_DAL_((?:.*?_H)|(?:.*?))(_H_\\d{8}|_U_|_I_)";


public String extractClient(String syncFileName) {
    Matcher matcher = ON_DEMAND_FILENAME_PATTERN.matcher(syncFileName);
    if (matcher.find()) {
        String client = matcher.group(1);
        String syncTypePart = matcher.group(2); // "_U_", "_I_", or "_H_"

        // Process H: client name in production is APE_H, IRP_BV_H etc.
        // The regex captures "APE" from "APE_H_20260518" because it stops at "_H_".
        // Reconstruct the full Historical client name by appending "_H".
        if ("_H_".equals(syncTypePart)) {
            client = client + "_H";
        }

        log.info("Extracted '{}' client Name for request file '{}'", client, syncFileName);
        return client;
    }
    log.info("No Client Name Found for the Expression '{}' for the request file '{}'",
            ON_DEMAND_FILENAME_REGEX, syncFileName);
    return "";
}

private String resolveBaseClientName(String clientName) {
    // Now that extractClient correctly returns APE_H,
    // scope is indexed under APE_H — no stripping needed.
    return clientName;
}

