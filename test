private Step buildStep(ProviderStepFactory factory,
                       JobRepository jobRepository,
                       @Qualifier("resourcelessTxManager")
                           PlatformTransactionManager transactionManager,
                       ItemReader<OnDemandScopeDetailsDto> sharedReader,
                       TaskExecutor stepTaskExecutor,
                       OnDemandRequestStepListener onDemandRequestStepListener,
                       Map<String, ItemProcessor<OnDemandScopeDetailsDto,
                           OnDemandScopeDetailsDto>> filtersByProvider) {

    CompositeItemProcessor<OnDemandScopeDetailsDto, List<OnDemandSecurityDto>> composite =
        new CompositeItemProcessor<>();
    composite.setDelegates(List.of(
        filtersByProvider.get(factory.getProviderId()),   // provider(+scope) — ONE delegate
        factory.processor()));

    return new StepBuilder(factory.getProviderId() + "-step", jobRepository)
            .<OnDemandScopeDetailsDto, List<OnDemandSecurityDto>>chunk(200, transactionManager)
            .reader(sharedReader)
            .processor(composite)
            .writer(factory.writer())
            .listener(onDemandRequestStepListener)
            .taskExecutor(stepTaskExecutor)
            .build();
}



@Bean
public Job processOnDemandRequest(
        JobRepository jobRepository,
        @Qualifier("resourcelessTxManager")
            PlatformTransactionManager transactionManager,
        ItemReader<OnDemandScopeDetailsDto> sharedReader,
        @Autowired Map<String, ProviderStepFactory> factories,
        TaskExecutor stepTaskExecutor,
        OnDemandRequestStepListener onDemandRequestStepListener,
        @Qualifier("bbgOnDemandFilter")
            ItemProcessor<OnDemandScopeDetailsDto, OnDemandScopeDetailsDto> bbgFilter,
        @Qualifier("fctOnDemandFilter")
            ItemProcessor<OnDemandScopeDetailsDto, OnDemandScopeDetailsDto> fctFilter) {

    Map<String, ItemProcessor<OnDemandScopeDetailsDto, OnDemandScopeDetailsDto>>
        filtersByProvider = Map.of(BLOOMBERG, bbgFilter, FACTSET, fctFilter);

    List<Flow> providerFlows = factories.values().stream()
            .map(factory -> {
                Step step = buildStep(
                    factory, jobRepository, transactionManager,
                    sharedReader, stepTaskExecutor,
                    onDemandRequestStepListener, filtersByProvider);
                return new FlowBuilder<Flow>(factory.getProviderId() + "-flow")
                        .start(step).build();
            })
            .collect(Collectors.toList());

    Flow parallel = new FlowBuilder<Flow>("parallel-split")
            .split(stepTaskExecutor)
            .add(providerFlows.toArray(new Flow[0]))
            .build();

    return new JobBuilder("ONDEMANDREQUEST-JOB", jobRepository)
            .incrementer(new RunIdIncrementer())
            .listener(onDemandRequestStepListener)
            .start(parallel)
            .end()
            .build();
}
