for (RequestParametersDto rp : item.getRequestParametersDtos()) {
    if (rp.getType() != FileType.ON_DEMAND_REQUEST) {
        continue;
    }
    code = rp.getParam_code();
    String value = rp.getParam_value();

    if (code == null || value == null) continue;

    if (code.equalsIgnoreCase(data)) {
        identifiers.add(value);

    } else if (code.equalsIgnoreCase(client)) {
        if (value.startsWith("DD")) {
            onDemandFileName = value;
        } else if (value.startsWith("BP2S")) {
            outputFileName = value;
        }

    } else if (FUNDS.equalsIgnoreCase(code) && UCITS_UNIT.equalsIgnoreCase(data)) {
        instrumentType = value;

    } else {
        String itemPriceExpr = Objects.toString(
                item.getItem().get(PRICE_EXPRESSION), "").trim();
        String expectedPeCode = itemPriceExpr + "_PE";

        if (!itemPriceExpr.isEmpty() && code.equalsIgnoreCase(expectedPeCode)) {
            priceExpression = value;
        } else if (DEFAULT.equalsIgnoreCase(code) && priceExpression.isEmpty()) {
            priceExpression = value;
        }
    }
}
