package com.bnpp.itg.tas.ido.muse.batch.client_diffusion;

import com.bnpp.itg.tas.ido.muse.data.dto.ClientReferenceDto;
import com.bnpp.itg.tas.ido.muse.service.diffusion.ClientScopeReader;
import com.bnpp.itg.tas.ido.muse.service.diffusion.ClientReferenceService;
import lombok.RequiredArgsConstructor;
import lombok.extern.log4j.Log4j2;
import org.springframework.batch.core.JobExecution;
import org.springframework.batch.core.StepExecution;
import org.springframework.batch.core.job.flow.FlowExecutionStatus;
import org.springframework.batch.core.job.flow.JobExecutionDecider;
import org.springframework.batch.core.scope.context.ChunkContext;

import java.io.IOException;
import java.time.LocalDateTime;

import static com.bnpp.itg.tas.ido.muse.data.constants.JobParametersConstants.*;
import static com.bnpp.itg.tas.ido.muse.data.constants.ErrorConstants.*;

@Log4j2
@RequiredArgsConstructor
public class DiffusionJobDecider implements JobExecutionDecider {

    private final ClientReferenceService clientReferenceService;
    private final ClientScopeReader reader;

    @Override
    public FlowExecutionStatus decide(JobExecution jobExecution, StepExecution stepExecution) {
        JobParameters jobParameters = jobExecution.getJobParameters();
        String clientName = jobParameters.getString(CLIENT_NAME);
        String instrument = jobParameters.getString(INSTRUMENT);
        String diffusedData = jobParameters.getString(DIFFUSED_DATA);
        String syncFileName = jobParameters.getString(SYNC_FILENAME);

        return isEligible(clientName, instrument, diffusedData, syncFileName)
                ? FlowExecutionStatus.COMPLETED
                : FlowExecutionStatus.STOPPED;
    }

    private boolean isEligible(String clientName, String instrument,
                                String diffusedData, String syncFileName) {
        ClientReferenceDto clientDto = clientReferenceService.getForClientName(clientName);

        // Process H: scope is indexed under base client name (APE, IRP_BV)
        // not the Historical client name (APE_H, IRP_BV_H).
        // Strip the _H suffix for scope lookup only.
        String scopeClientName = resolveBaseClientName(clientName);

        return isKnownClient(clientDto, clientName)
                && isSynchronised(clientDto.getInitSyncTime(), syncFileName,
                        instrument, diffusedData, clientName)
                && hasScopeToDiffuse(scopeClientName, clientDto.getInitSyncTime(),
                        instrument, diffusedData, syncFileName);
    }

    /**
     * Resolves the base client name used for ES scope lookup.
     * Historical clients (APE_H, IRP_BV_H) have their scope indexed
     * under the base client name (APE, IRP_BV).
     */
    private String resolveBaseClientName(String clientName) {
        if (clientName != null && clientName.endsWith("_H")) {
            return clientName.substring(0, clientName.length() - 2);
        }
        return clientName;
    }

    private boolean isKnownClient(ClientReferenceDto clientDto, String clientName) {
        if (clientDto == null) {
            log.error(UNKNOWN_CLIENT, clientName);
            return false;
        }
        return true;
    }

    private boolean isSynchronised(LocalDateTime initSynchroTime, String syncFileName,
                                    String instrument, String diffusedData, String clientName) {
        // Historical clients never have an initSyncTime (new client entries).
        // syncFileName alone is sufficient to confirm synchronization happened.
        boolean isHistorical = "HISTORICAL".equals(diffusedData);

        if (initSynchroTime == null && syncFileName == null && !isHistorical) {
            log.info("No file synchronized for this diffusion point: " +
                            "instrument '{}', diffusedData '{}' and client '{}'. " +
                            "Diffusion job aborted!",
                    instrument, diffusedData, clientName);
            return false;
        }
        return true;
    }

    private boolean hasScopeToDiffuse(String scopeClientName, LocalDateTime initSynchroTime,
                                       String instrument, String diffusedData,
                                       String syncFileName) {
        try {
            if (!reader.scopeExists(scopeClientName, initSynchroTime, instrument, syncFileName)) {
                log.info("No scope to be diffused for this diffusion point: " +
                                "instrument '{}', diffusedData '{}' and client '{}'. " +
                                "Diffusion job aborted!",
                        instrument, diffusedData, scopeClientName);
                return false;
            }
        } catch (IOException e) {
            log.error("An exception occurred while preparing diffusion job decision.", e);
            return false;
        }
        return true;
    }
}

SELECT param_code, param_value, type
FROM own_83650_muse.muse_request_parameters rp
JOIN own_83650_muse.muse_client_references cr
    ON rp.client_reference_id = cr.client_reference_id
WHERE cr.client_label = 'APE_H'
AND rp.type = 'ON_DEMAND_REQUEST';
