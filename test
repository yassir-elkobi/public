public class GenericProviderResponseProcessor implements ItemProcessor<JSONObject, ProcessedItemsDto> {

    // ... existing fields ...
    private String historicalDate;  // resolved once per file in init()

    public void init() {
        try {
            providerResponseEnricher = registry.getProcessor(
                    providerName.equals(BLOOMBERG) ? BLOOMBERG : GENERIC);
            providerResponseEnricher.enrichDataTypeDetails(providerData, vacationId, integrationId);
            charsetConversionValue = genericParameterService.getCharsetConversionDetails(CHARSET_CONVERSION);
            fileIntegrationDetailsService.updateFileReceivedStatus(integrationId, INTEGRATION_IN_PROGRESS);

            // Resolve the historical date ONCE per file (same for every item).
            // Returns null for non-historical files.
            historicalDate = providerResponseEnricher.resolveHistoricalDate(fileName);
        } catch (Exception e) {
            log.error("Initialization failed", e);
            fileIntegrationStatusUpdater.updateStatus(INTEGRATION_FAILED, integrationId);
        }
    }

    @Override
    public ProcessedItemsDto process(JSONObject item) throws Exception {
        Map<String, List<JSONObject>> indexDocumentsMap = new HashMap<>();
        LocalDateTime now = nowEuropeDateTime();
        DateTimeFormatter df = DateTimeFormatter.ofPattern(YYYY_MM_DD_HH_MM_SS_PATTERN);
        DateTimeFormatter rundateDf = DateTimeFormatter.ofPattern(RUNDATE_FORMAT);
        try {
            List<RequestParametersDto> requestParametersDto = requestParamService.getByProviderID(providerId);
            JSONObject processedItem = providerResponseEnricher.process(item, integrationId, requestParametersDto);
            if (processedItem == null) {
                return null;
            }
            // Pass the pre-resolved historicalDate down — no DB call per item
            providerResponseEnricher.enrichProcessedItem(processedItem, indexDocumentsMap,
                    charsetConversionValue, fileName, integrationId, historicalDate);

            indexDocumentsMap.values().forEach(list ->
                    list.forEach(json -> {
                        json.put(PROVIDER_FILENAME, fileName);
                        json.put(TIMESTAMP_FIELD, now.format(df));
                        json.put(RUNDATE, now.format(rundateDf));
                    }));
            return ProcessedItemsDto.builder()
                    .indexDocumentsMap(indexDocumentsMap)
                    .build();
        } catch (Exception e) {
            log.error(ErrorConstants.PROCESSING_FAILED, e);
            fileIntegrationStatusUpdater.updateStatus(INTEGRATION_FAILED, integrationId);
            return null;
        }
    }
}




