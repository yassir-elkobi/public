private SearchRequest buildSearchRequest(SecurityItem item, IndexProcess index, String instrument) {
    List<Query> queries = index.buildProviderQueries(item.getSecurity(), instrument);
    Query boolQuery = BoolQuery.of(b -> b.must(queries))._toQuery();
    SearchRequest req = SearchRequest.of(s -> s
            .query(boolQuery)
            .index(index.getEsIndexName())
            .sort(so -> so.field(f -> f.field(TIMESTAMP_FIELD).order(SortOrder.Desc)))
            .size(1));
    
    log.info("HISTORICAL search query: {}", req.query());  // TEMP — dump the query
    return req;
}


