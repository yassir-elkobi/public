    @Test
    public void testRequestParamsFilteredForHistoricalClient() {
        // Scope item with HISTORICAL client APE_H — should use findByClientReferenceIdOrGeneric, not findAll
        JSONObject json = new JSONObject();
        json.put("CLIENT", "APE_H");
        json.put("STATIC_FLAG", "Y");
        List<JSONObject> scope = Collections.singletonList(json);

        ClientReferenceDto apeHRef = ClientReferenceDto.builder()
                .id(14L)
                .clientLabel("APE_H")
                .build();

        when(onDemandRequestService.getOnDemandVacationNamesById()).thenReturn(onDemandVacationNamesById);
        when(onDemandRequestService.getInstrumentAndSubInstMappingsByVacationId(anyInt())).thenReturn(instrSubInstMappings);
        when(onDemandRequestService.getHeaderParams(any())).thenReturn(headerParamDtoList);
        when(onDemandRequestService.getVacationFields(any(), eq(true))).thenReturn(fieldList);
        when(onDemandRequestService.getVacConfigByVacRefId(anyInt())).thenReturn(vacConfigDetails);
        when(instrumentReferenceService.getAllValidInstrumentCodeByInstrumentId()).thenReturn(instrumentCodesByInstrumentId);
        when(clientReferenceService.getForClientName("APE_H")).thenReturn(apeHRef);
        when(requestParamService.findByClientReferenceIdOrGeneric(14L)).thenReturn(Collections.emptyList());

        List<OnDemandScopeDetailsDto> result = onDemandFeedDetailsRetriever.getVacationDetails(scope, syncFileName);

        assertNotNull(result);
        assertEquals(1, result.size());
        // Verify the client-specific method was used, not findAll
        verify(requestParamService).findByClientReferenceIdOrGeneric(14L);
        verify(requestParamService, never()).findAll();
    }

    @Test
    public void testRequestParamsFallsBackToFindAllWhenClientUnknown() {
        // Scope item with unknown client — should fall back to findAll
        JSONObject json = new JSONObject();
        json.put("CLIENT", "UNKNOWN_CLIENT");
        json.put("STATIC_FLAG", "Y");
        List<JSONObject> scope = Collections.singletonList(json);

        when(onDemandRequestService.getOnDemandVacationNamesById()).thenReturn(onDemandVacationNamesById);
        when(onDemandRequestService.getInstrumentAndSubInstMappingsByVacationId(anyInt())).thenReturn(instrSubInstMappings);
        when(onDemandRequestService.getHeaderParams(any())).thenReturn(headerParamDtoList);
        when(onDemandRequestService.getVacationFields(any(), eq(true))).thenReturn(fieldList);
        when(onDemandRequestService.getVacConfigByVacRefId(anyInt())).thenReturn(vacConfigDetails);
        when(instrumentReferenceService.getAllValidInstrumentCodeByInstrumentId()).thenReturn(instrumentCodesByInstrumentId);
        when(clientReferenceService.getForClientName("UNKNOWN_CLIENT")).thenReturn(null);
        when(requestParamService.findAll()).thenReturn(Collections.emptyList());

        List<OnDemandScopeDetailsDto> result = onDemandFeedDetailsRetriever.getVacationDetails(scope, syncFileName);

        assertNotNull(result);
        verify(requestParamService).findAll();
        verify(requestParamService, never()).findByClientReferenceIdOrGeneric(anyLong());
    }
}
