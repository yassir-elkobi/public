    public List<OnDemandScopeDetailsDto> getVacationDetails(List<JSONObject> jsonObjectsOfScope,
                                                            String syncFileName) {
        VacationContext ctx = loadVacationContext(syncFileName);
        Map<String, List<RequestParametersDto>> paramsByClient = new HashMap<>();

        return jsonObjectsOfScope.stream()
                .map(security -> buildScopeDetails(security, ctx, paramsByClient))
                .collect(Collectors.toList());
    }

    /** Loads the per-vacation reference data once, shared across every security in the scope. */
    private VacationContext loadVacationContext(String syncFileName) {
        Map<Integer, String> vacationNamesById = onDemandRequestService.getOnDemandVacationNamesById();
        return new VacationContext(
                vacationNamesById,
                getInstrSubInstMappingsByVacationName(vacationNamesById),
                getHeaderParamsForVacation(vacationNamesById, syncFileName),
                getFieldListForVacation(vacationNamesById),
                getVacConfigDetailsByVacationName(vacationNamesById),
                instrumentReferenceService.getAllValidInstrumentCodeByInstrumentId());
    }

    private OnDemandScopeDetailsDto buildScopeDetails(JSONObject security, VacationContext ctx,
                                                      Map<String, List<RequestParametersDto>> paramsByClient) {
        String securityClient = (String) security.get(CLIENT);
        List<RequestParametersDto> clientParams =
                paramsByClient.computeIfAbsent(securityClient, this::loadParamsForClient);

        return OnDemandScopeDetailsDto.builder()
                .headerParams(ctx.headerParams())
                .fieldListByVacationName(ctx.fieldListByVacationName())
                .feedInstrList(ctx.feedInstrList())
                .instrumentCodesByInstrumentId(ctx.instrumentCodesByInstrumentId())
                .vacConfigDetailsByVacName(ctx.vacConfigDetailsByVacName())
                .item(security)
                .onDemandVacationNamesById(ctx.vacationNamesById())
                .requestParametersDtos(clientParams)
                .providerName(resolveProviders(security))
                .build();
    }

    private List<String> resolveProviders(JSONObject security) {
        List<String> providers = new ArrayList<>();
        if ("Y".equals(security.get(STATIC_FLAG)) || "Y".equals(security.get(PRICE_FLAG))) {
            providers.add(BLOOMBERG);
        }
        if ("Y".equals(security.get(DERIVED_FLAG))) {
            providers.add(FACTSET);
        }
        return providers;
    }

    /**
     * Returns the request parameters scoped to the given client (plus generic rows where
     * client_reference_id is null). Falls back to all parameters when the client is unknown.
     */
    private List<RequestParametersDto> loadParamsForClient(String clientName) {
        if (clientName == null || clientName.isBlank()) {
            return requestParamService.findAll();
        }
        ClientReferenceDto clientRef = clientReferenceService.getForClientName(clientName);
        if (clientRef == null) {
            log.warn("No client reference found for '{}' - falling back to all request parameters",
                    clientName);
            return requestParamService.findAll();
        }
        return requestParamService.findByClientReferenceIdOrGeneric(clientRef.getId());
    }

