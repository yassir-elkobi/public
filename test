    private List<RequestParametersDto> requestParametersDtos;

    // Computed once at job level — same value for every item in this run.
    // Prevents midnight-crossing inconsistency where items processed before
    // and after midnight would otherwise get different dates.
    private String today;
    private String yesterday;
}
