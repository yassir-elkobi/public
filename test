        when(onDemandRequestService.getInstrumentAndSubInstMappingsByVacationId(anyInt())).thenReturn(Collections.emptyList());
        when(onDemandRequestService.getOnDemandVacationNamesById()).thenReturn(onDemandVacationNamesById);
