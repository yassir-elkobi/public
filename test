// Only the methods touched for Process H are shown — paste these over the
// existing buildDerivedQueries / buildHistoricalQueries in QueryBuilder.java.
// Everything else in QueryBuilder is unchanged.

    public static List<Query> buildDerivedQueries(JSONObject securityItem, String instrument) {
        return buildDerivedFamilyQueries(securityItem, instrument, DERIVED_INDEX);
    }

    public static List<Query> buildHistoricalQueries(JSONObject securityItem, String instrument) {
        return buildDerivedFamilyQueries(securityItem, instrument, HISTORICAL);
    }

    /**
     * Shared builder for the derived index family (DERIVED + HISTORICAL).
     * HISTORICAL additionally constrains the query to the requested historical date,
     * which is carried on the security item from the synchronisation file.
     */
    private static List<Query> buildDerivedFamilyQueries(JSONObject securityItem, String instrument,
                                                         IndexProcess indexProcess) {
        String providerIdentifierField = indexProcess.getProviderIdentifierField(instrument);
        List<String> clientIdentifierFields = indexProcess.getClientIdentifierFields(instrument);

        BoolQuery.Builder query = QueryBuilders.bool()
                .must(buildIdentifierClause(securityItem, providerIdentifierField, clientIdentifierFields))
                .must(matchPhrase(PROVIDER_DATATYPE, indexProcess.getIndexParam()));

        if (indexProcess == HISTORICAL) {
            addHistoricalDateFilter(query, securityItem);
        }
        return List.of(query.build()._toQuery());
    }

    private static Query buildIdentifierClause(JSONObject securityItem, String providerIdentifierField,
                                               List<String> clientIdentifierFields) {
        BoolQuery.Builder clause = QueryBuilders.bool();
        if (clientIdentifierFields.size() == 1) {
            clause.must(matchPhrase(providerIdentifierField,
                    (String) securityItem.get(clientIdentifierFields.get(0))));
            return clause.build()._toQuery();
        }
        for (String field : clientIdentifierFields) {
            Object value = securityItem.get(field);
            if (nonNull(value) && isNotBlank(value.toString())) {
                clause.should(matchPhrase(providerIdentifierField, (String) value));
            }
        }
        return clause.build()._toQuery();
    }

    private static void addHistoricalDateFilter(BoolQuery.Builder query, JSONObject securityItem) {
        String historicalDate = Objects.toString(securityItem.get(HISTORICAL_DATE), "").trim();
        if (!historicalDate.isEmpty()) {
            query.must(matchPhrase(HISTORICAL_DATE, historicalDate));
        }
    }






package com.bnpp.itg.tas.ido.muse.service.ondemandrequest;

import com.fasterxml.jackson.databind.JsonNode;
import com.fasterxml.jackson.databind.ObjectMapper;
import lombok.extern.log4j.Log4j2;
import org.json.simple.JSONObject;
import org.springframework.stereotype.Service;

import java.time.LocalDate;
import java.time.format.DateTimeFormatter;
import java.util.ArrayList;
import java.util.HashSet;
import java.util.List;
import java.util.Map;
import java.util.Objects;
import java.util.Set;
import java.util.stream.StreamSupport;

import com.bnpp.itg.tas.ido.muse.data.dto.OnDemandScopeDetailsDto;
import com.bnpp.itg.tas.ido.muse.data.dto.RequestParametersDto;
import com.bnpp.itg.tas.ido.muse.data.enums.FileType;
import com.bnpp.itg.tas.ido.muse.util.InstrumentTypeMapper;

import static com.bnpp.itg.tas.ido.muse.data.constants.ElasticsearchFieldsConstants.*;
import static com.bnpp.itg.tas.ido.muse.data.constants.OnDemandRequestConstants.*;
import static com.bnpp.itg.tas.ido.muse.util.FileUtils.computeUniqueIdentifier;
import static com.bnpp.itg.tas.ido.muse.util.OnDemand.isIdentifierAllowed;

@Log4j2
@Service
public class DemandHandlerImpl implements DemandHandler {

    private static final ObjectMapper MAPPER = new ObjectMapper();
    private static final DateTimeFormatter DATE_FORMATTER = DateTimeFormatter.ofPattern("yyyyMMdd");
    private static final String REQUEST_FILE_PREFIX = "DD";
    private static final String OUTPUT_FILE_PREFIX = "BP2S";
    private static final String PRICE_EXPRESSION_SUFFIX = "_PE";
    private static final String COMPOUND_DELIMITER = "-";
    private static final String DEFAULT_REQUEST_EXTENSION = ".req";

    @Override
    public String getOnDemandFileName(String fileName) {
        String uniqueId = computeUniqueIdentifier();
        int dotIdx = fileName.lastIndexOf('.');
        if (dotIdx > 0) {
            return fileName.substring(0, dotIdx) + "-" + uniqueId + fileName.substring(dotIdx);
        }
        return fileName + "-" + uniqueId + DEFAULT_REQUEST_EXTENSION;
    }

    @Override
    public List<JSONObject> generateOutputResult(OnDemandScopeDetailsDto item) {
        List<JSONObject> outputList = new ArrayList<>();
        try {
            ResolvedRequestParams params = resolveRequestParams(item);
            RequestDates dates = resolveDates(item);

            String onDemandFileName = dates.isHistorical() && !params.onDemandFileName().isEmpty()
                    ? toHistoricalFileName(params.onDemandFileName())
                    : params.onDemandFileName();

            JsonNode rootNode = MAPPER.readTree(String.valueOf(item.getHeaderParams().get(FACTSET)));
            Set<String> processedIdentifiers = new HashSet<>();

            for (String identifier : params.identifiers()) {
                String identifierStr = resolveIdentifierValue(item, identifier);
                if (identifierStr == null || !processedIdentifiers.add(identifierStr)) {
                    continue;
                }
                JSONObject output = new JSONObject();
                populateResultForIdentifier(item, output, rootNode, identifier, params, dates,
                        onDemandFileName);
                outputList.add(output);
            }
        } catch (Exception e) {
            log.error("Error in OnDemand request file format for {}", item.getProviderName(), e);
        }
        return outputList;
    }

    /**
     * Walks the request parameters once and resolves the file names, instrument type,
     * price expression and identifier list for this security's client.
     */
    private ResolvedRequestParams resolveRequestParams(OnDemandScopeDetailsDto item) {
        String instrument = (String) item.getItem().get(INSTRUMENT);
        String client = (String) item.getItem().get(CLIENT);
        String itemPriceExpr = Objects.toString(item.getItem().get(PRICE_EXPRESSION), "").trim();
        String priceExpressionCode = itemPriceExpr.isEmpty() ? null : itemPriceExpr + PRICE_EXPRESSION_SUFFIX;

        List<String> identifiers = new ArrayList<>();
        String onDemandFileName = "";
        String outputFileName = "";
        String instrumentType = "";
        String priceExpression = "";
        boolean fundsInstrumentType = false;

        for (RequestParametersDto rp : item.getRequestParametersDtos()) {
            if (rp.getType() != FileType.ON_DEMAND_REQUEST) {
                continue;
            }
            String code = rp.getParam_code();
            String value = rp.getParam_value();
            if (code == null || value == null) {
                continue;
            }

            if (code.equalsIgnoreCase(instrument)) {
                identifiers.add(value);
            } else if (code.equalsIgnoreCase(client)) {
                if (value.startsWith(REQUEST_FILE_PREFIX)) {
                    onDemandFileName = value;
                } else if (value.startsWith(OUTPUT_FILE_PREFIX)) {
                    outputFileName = value;
                }
            } else if (FUNDS.equalsIgnoreCase(code) && UCITS_UNIT.equalsIgnoreCase(instrument)) {
                instrumentType = value;
                fundsInstrumentType = true;
            } else if (code.equalsIgnoreCase(priceExpressionCode)) {
                priceExpression = value;
            } else if (DEFAULT.equalsIgnoreCase(code) && priceExpression.isEmpty()) {
                priceExpression = value;
            }
        }
        return new ResolvedRequestParams(identifiers, onDemandFileName, outputFileName,
                instrumentType, priceExpression, fundsInstrumentType);
    }

    private RequestDates resolveDates(OnDemandScopeDetailsDto item) {
        String historicalDate = Objects.toString(item.getItem().get(HISTORICAL_DATE), "").trim();
        boolean isHistorical = !historicalDate.isBlank();
        String today = LocalDate.now().format(DATE_FORMATTER);
        String yesterday = LocalDate.now().minusDays(1).format(DATE_FORMATTER);
        // Historical: the request date inside the file is the requested historical date.
        // OnDemand (U/I): the request date is yesterday.
        String requestDate = isHistorical ? historicalDate : yesterday;
        return new RequestDates(isHistorical, isHistorical ? historicalDate : null, today, requestDate);
    }

    private String resolveIdentifierValue(OnDemandScopeDetailsDto item, String identifier) {
        Object value = item.getItem().get(identifier);
        if (value instanceof String s) {
            return s.trim().isEmpty() ? null : s;
        }
        return value == null ? null : value.toString();
    }

    /**
     * The on-demand request file name always carries today's date (when the request is
     * generated); the historical date lives inside the file content instead.
     */
    private String toHistoricalFileName(String onDemandFileName) {
        int dotIdx = onDemandFileName.lastIndexOf('.');
        String base = (dotIdx > 0) ? onDemandFileName.substring(0, dotIdx) : onDemandFileName;
        String ext = (dotIdx > 0) ? onDemandFileName.substring(dotIdx) : DEFAULT_REQUEST_EXTENSION;
        String today = LocalDate.now().format(DATE_FORMATTER);

        String historicalBase;
        if (base.endsWith("_U") || base.endsWith("_I")) {
            historicalBase = base.substring(0, base.length() - 2) + "_H_" + today;
        } else if (base.endsWith("_H")) {
            historicalBase = base + "_" + today;
        } else {
            historicalBase = base + "_H_" + today;
        }
        return historicalBase + ext;
    }

    private void populateResultForIdentifier(OnDemandScopeDetailsDto item, JSONObject output,
                                             JsonNode root, String identifier,
                                             ResolvedRequestParams params, RequestDates dates,
                                             String onDemandFileName) {
        Map<String, Object> itemMap = item.getItem();
        boolean skipBond = BOND.equalsIgnoreCase((String) itemMap.get(INSTRUMENT))
                && isIdentifierAllowed((String) itemMap.get(SECURITY_IDENTIFIER));

        StreamSupport.stream(root.spliterator(), false)
                .map(node -> node.path(CODE).asText(null))
                .filter(Objects::nonNull)
                .forEach(field -> {
                    if (!skipBond) {
                        populateField(output, itemMap, field, identifier, params, dates.requestDate());
                    }
                });

        output.put(DATE, dates.requestDate());
        output.put(ON_DEMAND_FILENAME, onDemandFileName);
        output.put(OUTPUT_FILENAME, appendDate(params.outputFileName(), dates.today()));

        if (dates.historicalDate() != null) {
            output.put(HISTORICAL_DATE, dates.historicalDate());
        }
    }

    private String appendDate(String fileName, String date) {
        int dotIdx = fileName.lastIndexOf('.');
        String base = (dotIdx > 0) ? fileName.substring(0, dotIdx) : fileName;
        String ext = (dotIdx > 0) ? fileName.substring(dotIdx) : "";
        return base + date + ext;
    }

    /**
     * Resolves a single Factset output field. Each field type owns its own resolver
     * so the dispatch reads top to bottom with no nested branching.
     */
    private void populateField(JSONObject output, Map<String, Object> itemMap, String field,
                               String identifier, ResolvedRequestParams params, String requestDate) {
        FieldKind kind = FieldKind.classify(field, params.instrumentType(), params.fundsInstrumentType());

        switch (kind) {
            case FUNDS_COMPOUND -> output.put(field, resolveFundsCompound(itemMap, identifier, params));
            case PROVIDER_COMPOUND -> output.put(field, resolveProviderCompound(itemMap, identifier, field));
            case PRICE_EXPRESSION_FIELD -> output.put(field, resolvePriceExpression(itemMap, identifier, params.priceExpression()));
            case SYNONYM_CODE_FIELD -> output.put(field, itemMap.get(identifier.toUpperCase()));
            case INSTRUMENT_TYPE_FIELD -> output.put(field, InstrumentTypeMapper.getDisplayValue((String) itemMap.get(INSTRUMENT)));
            case DATE_FIELD -> output.put(field, requestDate);
            case PLAIN -> output.put(field, itemMap.get(field.replace(' ', '_').toUpperCase()));
        }
    }

    private Object resolveFundsCompound(Map<String, Object> itemMap, String identifier,
                                        ResolvedRequestParams params) {
        Object left = itemMap.get(identifier.toUpperCase());
        String[] parts = params.instrumentType().split("\\|");
        return parts.length > 1 ? left + COMPOUND_DELIMITER + itemMap.get(parts[1].toUpperCase()) : left;
    }

    private Object resolveProviderCompound(Map<String, Object> itemMap, String identifier, String field) {
        Object left = itemMap.get(identifier.toUpperCase());
        String[] parts = field.split(COMPOUND_DELIMITER, 2);
        if (parts.length <= 1) {
            return left;
        }
        Object right = itemMap.get(normalizeKey(parts[1]));
        if (right == null) {
            log.debug("populateField: right-side key '{}' not found for field '{}'", parts[1], field);
            return left;
        }
        return left + COMPOUND_DELIMITER + right;
    }

    private Object resolvePriceExpression(Map<String, Object> itemMap, String identifier,
                                          String priceExpression) {
        if (priceExpression == null || !priceExpression.contains(COMPOUND_DELIMITER)) {
            return priceExpression;
        }
        String[] parts = priceExpression.split(COMPOUND_DELIMITER, 2);
        Object right = itemMap.get(normalizeKey(parts[1]));
        Object left = itemMap.get(identifier.toUpperCase());
        return right != null ? left + COMPOUND_DELIMITER + right : priceExpression;
    }

    private static String normalizeKey(String key) {
        return key.trim().replace(' ', '_').toUpperCase();
    }

    // ---- value objects -----------------------------------------------------

    private record ResolvedRequestParams(List<String> identifiers, String onDemandFileName,
                                         String outputFileName, String instrumentType,
                                         String priceExpression, boolean fundsInstrumentType) {
    }

    private record RequestDates(boolean isHistorical, String historicalDate, String today,
                                String requestDate) {
    }

    private enum FieldKind {
        FUNDS_COMPOUND, PROVIDER_COMPOUND, PRICE_EXPRESSION_FIELD, SYNONYM_CODE_FIELD,
        INSTRUMENT_TYPE_FIELD, DATE_FIELD, PLAIN;

        static FieldKind classify(String field, String instrumentType, boolean fundsInstrumentType) {
            if (field.contains(COMPOUND_DELIMITER)) {
                return (!instrumentType.isEmpty() && fundsInstrumentType)
                        ? FUNDS_COMPOUND : PROVIDER_COMPOUND;
            }
            if (field.equalsIgnoreCase(PRICE_EXPRESSION.replace("_", " "))) return PRICE_EXPRESSION_FIELD;
            if (field.equalsIgnoreCase(SYNONYM_CODE)) return SYNONYM_CODE_FIELD;
            if (field.equalsIgnoreCase(INSTRUMENT_TYPE)) return INSTRUMENT_TYPE_FIELD;
            if (field.equalsIgnoreCase(DATE)) return DATE_FIELD;
            return PLAIN;
        }
    }
}





