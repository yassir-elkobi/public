-- APE_H Historical synchronization config
INSERT INTO own_83650_muse.muse_synchronization_configs
    (client_reference_id, filename_pattern, sync_type, user_name, created_at, updated_at)
SELECT
    cr.client_reference_id,
    '^MUSE_Sync_DAL_APE_H_[0-9]+_[0-9]+\.csv$',
    'HISTORICAL',
    'MUSE_INIT',
    current_timestamp,
    current_timestamp
FROM own_83650_muse.muse_client_references cr
WHERE cr.client_label = 'APE_H'
AND NOT EXISTS (
    SELECT 1 FROM own_83650_muse.muse_synchronization_configs sc
    JOIN own_83650_muse.muse_client_references cr2
        ON sc.client_reference_id = cr2.client_reference_id
    WHERE cr2.client_label = 'APE_H'
    AND sc.sync_type = 'HISTORICAL'
);

