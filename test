private JSONObject buildDiffusionSecurity(
        List<JSONObject> providerData, JSONObject security, DiffusionStepContextI context) {

    boolean isDerived = DERIVED_INDEX == context.providerIndexProcess()
            || HISTORICAL == context.providerIndexProcess();  // ← fix
    boolean isWarrant = BONDS_RIGHTS_WARRANTS.equals(security.get(INSTRUMENT));
    String providerName = BLOOMBERG;
    if (isDerived) {
        providerName = isWarrant ? DATALICENSE : FACTSET;  // HISTORICAL → FACTSET ✅
    }

    JSONObject diffusionSecurity = fieldProcessor.mapProviderFields(providerData, context);
    diffusionSecurity.put(HEADER_FIELD_INTERNAL_ID, security.get(INTERNAL_IDENTIFIER));
    diffusionSecurity.put(HEADER_FIELD_ISIN, security.get(SECURITY_IDENTIFIER));
    diffusionSecurity.put(HEADER_FIELD_MARKET_PLACE, security.get(MARKET_PLACE));
    diffusionSecurity.put(HEADER_FIELD_PRODUCT_CODE, context.clientProductCode());
    diffusionSecurity.put(isDerived
            ? MISSING_FIELD_AMANDA_CURRENCY
            : HEADER_FIELD_AMANDA_CURRENCY, security.get(CURRENCY));
    diffusionSecurity.put(HEADER_FIELD_NOVAL, security.get(NOVAL));
    diffusionSecurity.put(HEADER_FIELD_SEDOL_HIPORT, security.get(SEDOL_HIPORT));
    diffusionSecurity.put(HEADER_FIELD_HP_SYDNEY, security.get(HP_SYDNEY_ID));
    diffusionSecurity.put(HEADER_FIELD_DIMENSION, security.get(DIMENSION_ID));
    diffusionSecurity.put(HEADER_FIELD_TICKER, (StringUtils.isEmpty((String) security.get(TICKER))
            ? security.get(BLOOM_LUX_FO) : security.get(TICKER)));
    diffusionSecurity.put(HEADER_FIELD_FACTSET, (StringUtils.isEmpty((String) security.get(FACTSET_ID))
            ? security.get(FACTSET_LUX_FO) : security.get(FACTSET_ID)));
    diffusionSecurity.put(HEADER_FIELD_PROVIDER, providerName);

    // Propagate HISTORICAL_DATE for Historical diffusion output
    if (HISTORICAL == context.providerIndexProcess()) {
        String historicalDate = Objects.toString(
                security.get(HISTORICAL_DATE), StringUtils.EMPTY);
        diffusionSecurity.put(HISTORICAL_DATE, historicalDate);
    }

    return fieldProcessor.applyFieldFormatting(diffusionSecurity, context);
}
