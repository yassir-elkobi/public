package com.bnpp.itg.tas.ido.muse.batch.response_integration;

import com.bnpp.itg.tas.ido.muse.data.constants.ErrorConstants;
import com.bnpp.itg.tas.ido.muse.data.constants.FactSetConstants;
import com.bnpp.itg.tas.ido.muse.data.dto.ClientReferenceDto;
import com.bnpp.itg.tas.ido.muse.data.dto.DiffusionCommand;
import com.bnpp.itg.tas.ido.muse.data.dto.FileIntegrationDetailsDto;
import com.bnpp.itg.tas.ido.muse.data.dto.RequestDetailsDto;
import com.bnpp.itg.tas.ido.muse.service.diffusion.DiffusionHandler;
import com.bnpp.itg.tas.ido.muse.service.integration.FileIntegrationDetailsService;
import com.bnpp.itg.tas.ido.muse.service.ondemandrequest.ClientReferenceService;
import com.bnpp.itg.tas.ido.muse.service.ondemandrequest.RequestDetailsService;
import lombok.RequiredArgsConstructor;
import lombok.extern.log4j.Log4j2;
import org.springframework.batch.core.JobExecution;
import org.springframework.batch.core.JobExecutionListener;
import org.springframework.batch.core.JobParameters;
import org.springframework.batch.core.StepExecution;
import org.springframework.batch.core.StepExecutionListener;
import org.springframework.batch.core.BatchStatus;
import org.springframework.stereotype.Component;

import java.util.List;
import java.util.Optional;
import java.util.regex.Matcher;
import java.util.stream.Collectors;

import static com.bnpp.itg.tas.ido.muse.data.constants.FactSetConstants.FACTSET_FILENAME_PATTERN_COMPILED;
import static com.bnpp.itg.tas.ido.muse.data.constants.OnDemandRequestConstants.INTEGRATION_ID;
import static com.bnpp.itg.tas.ido.muse.data.constants.OnDemandRequestConstants.ORIGINAL_FILENAME;
import static com.bnpp.itg.tas.ido.muse.data.constants.OnDemandRequestConstants.PROVIDER;
import static com.bnpp.itg.tas.ido.muse.data.constants.ProviderConstants.FACTSET;
import static com.bnpp.itg.tas.ido.muse.data.enums.FileIntegrationStatus.INTEGRATION_FAILED;
import static com.bnpp.itg.tas.ido.muse.data.enums.FileIntegrationStatus.INTEGRATION_IN_PROGRESS;
import static com.bnpp.itg.tas.ido.muse.data.enums.FileIntegrationStatus.INTEGRATION_SUCCESSFUL;
import static com.bnpp.itg.tas.ido.muse.data.enums.RequestStatus.RESPONSE_RECEIVED;
import static com.bnpp.itg.tas.ido.muse.util.FileUtils.getFileNameWithoutExtension;

@Component
@RequiredArgsConstructor
@Log4j2
public class ProcessProviderResponseJobListener
        implements JobExecutionListener, StepExecutionListener {

    private final FileIntegrationDetailsService fileIntegrationDetailsService;
    private final DiffusionHandler diffusionHandler;
    private final RequestDetailsService requestDetailsService;
    private final ClientReferenceService clientReferenceService;

    @Override
    public void beforeStep(StepExecution stepExecution) {
        Long integrationId = stepExecution.getJobParameters().getLong(INTEGRATION_ID);
        try {
            fileIntegrationDetailsService.updateFileReceivedStatus(
                integrationId, INTEGRATION_IN_PROGRESS);
        } catch (Exception e) {
            log.error(ErrorConstants.FAILED_TO_UPDATE_INTEGRATION_STATUS
                .formatted(INTEGRATION_IN_PROGRESS), e);
        }
    }

    @Override
    public void afterJob(JobExecution jobExecution) {
        JobParameters jobParameters = jobExecution.getJobParameters();
        Long integrationId = jobParameters.getLong(INTEGRATION_ID);
        String integratedFilename = jobParameters.getString(ORIGINAL_FILENAME);
        String provider = jobParameters.getString(PROVIDER);

        if (jobExecution.getStatus() == BatchStatus.COMPLETED) {
            try {
                fileIntegrationDetailsService.updateFileReceivedStatus(
                    integrationId, INTEGRATION_SUCCESSFUL);
                requestDetailsService.updateRequestStatus(
                    integratedFilename, RESPONSE_RECEIVED);
            } catch (Exception e) {
                log.error(ErrorConstants.FAILED_TO_UPDATE_INTEGRATION_STATUS
                    .formatted(INTEGRATION_SUCCESSFUL), e);
            }

            FileIntegrationDetailsDto responseIntegratedFile =
                fileIntegrationDetailsService.getByIntegrationId(integrationId).get();

            if (FACTSET.equalsIgnoreCase(provider)) {
                processFactSetDiffusion(responseIntegratedFile);
            } else {
                triggerOnDemandDiffusionIfNeeded(responseIntegratedFile);
            }

        } else {
            try {
                fileIntegrationDetailsService.updateFileReceivedStatus(
                    integrationId, INTEGRATION_FAILED);
            } catch (Exception e) {
                log.error(ErrorConstants.FAILED_TO_UPDATE_INTEGRATION_STATUS
                    .formatted(INTEGRATION_FAILED), e);
            }
        }
    }

    private void triggerOnDemandDiffusionIfNeeded(
            FileIntegrationDetailsDto responseIntegratedFile) {
        String responseFilename = responseIntegratedFile.getFilename();
        Optional<RequestDetailsDto> maybeRequestDetails =
            requestDetailsService.getLastByResponseFilename(responseFilename);

        if (maybeRequestDetails.isEmpty()) {
            log.info("There is no request associated to this integrated provider"
                + " response file '{}', no diffusion to be processed !",
                responseFilename);
            return;
        }

        RequestDetailsDto requestDetails = maybeRequestDetails.get();
        String requestIdentifier = requestDetails.getRequestIdentifier();

        if (requestDetails.isOnDemandActive()
                && requestDetailsService.isResponseReceivedForAllRequestFiles(
                    requestIdentifier)) {
            ClientReferenceDto client = requestDetails.getClientReference();
            log.info("All response files have been integrated for the"
                + " synchronisation file '{}', with the '{}' request identifier,"
                + " proceeding to diffusion for '{}' client ...",
                requestDetails.getSyncFilename(), requestIdentifier,
                client.getClientLabel());

            List<FileIntegrationDetailsDto> responseFiles =
                requestDetailsService.getAllByRequestIdentifier(requestIdentifier)
                    .stream()
                    .map(request ->
                        fileIntegrationDetailsService.getByResponseFilenamePrefix(
                            getFileNameWithoutExtension(
                                request.getRequestFilename()))
                            .orElse(null))
                    .collect(Collectors.toList());

            diffusionHandler.processAllDiffusionsForClient(
                client,
                Optional.of(responseFiles),
                Optional.of(requestDetails.getSyncFilename()));
        }
    }

    /**
     * Routes a FactSet response file to the correct diffusion path.
     * Historical files (DD_OUTPUT_..._H_...) go to {@link #diffuseHistorical};
     * everything else follows the existing derived path {@link #diffuseDerived}.
     */
    private void processFactSetDiffusion(
            FileIntegrationDetailsDto responseIntegratedFile) {
        String responseFilename = responseIntegratedFile.getFilename();
        log.info("Processing {} response file '{}' for diffusion...",
            FACTSET, responseFilename);

        String filenameWithoutExt = getFileNameWithoutExtension(responseFilename);

        Matcher historical = FactSetConstants
            .FACTSET_HISTORICAL_FILENAME_PATTERN_COMPILED
            .matcher(filenameWithoutExt);

        if (historical.matches()) {
            diffuseHistorical(historical.group(1), historical.group(2),
                responseFilename);
            return;
        }

        diffuseDerived(responseIntegratedFile);
    }

    /**
     * Historical diffusion: DD_OUTPUT_{INSTRUMENT}_{CLIENT}_H_{YYYYMMDD}_{ID}.txt
     * Resolves the dedicated "_H" client (e.g. APE_H, IRP_BV_H) and diffuses HISTORICAL data.
     */
    private void diffuseHistorical(String instrumentCode, String clientToken,
            String responseFilename) {
        String instrumentType =
            FactSetConstants.HISTORICAL_INSTRUMENT_CODE_TO_TYPE.get(instrumentCode);
        String baseLabel =
            FactSetConstants.HISTORICAL_CLIENT_TOKEN_TO_LABEL.get(clientToken);

        if (instrumentType == null || baseLabel == null) {
            log.error("Unknown instrument '{}' or client '{}' in historical"
                + " filename '{}', skipping diffusion",
                instrumentCode, clientToken, responseFilename);
            return;
        }

        String clientLabel = baseLabel + "_H";

        Optional<ClientReferenceDto> client =
            clientReferenceService.getClientByClientLabel(clientLabel);

        if (client.isEmpty() || !client.get().isOnDemandActive()) {
            log.info("Historical client '{}' not found or on-demand inactive,"
                + " skipping diffusion", clientLabel);
            return;
        }

        log.info("FactSet HISTORICAL response '{}': client='{}', instrument='{}',"
            + " diffusedData='{}'", responseFilename, clientLabel, instrumentType,
            FactSetConstants.DIFFUSED_DATA_HISTORICAL);

        diffusionHandler.processDiffusionCommand(DiffusionCommand.builder()
                .clientName(clientLabel)
                .instrument(instrumentType)
                .diffusedData(FactSetConstants.DIFFUSED_DATA_HISTORICAL)
                .build());
    }

    /**
     * Derived diffusion (existing flow): BP2S_DT{letter}_{code}_DD_{n}_{n}
     * Resolves the on-demand-active client by letter and diffuses DERIVED data.
     */
    private void diffuseDerived(FileIntegrationDetailsDto responseIntegratedFile) {
        String responseFilename = responseIntegratedFile.getFilename();

        String filenameWithoutExt = getFileNameWithoutExtension(responseFilename);
        Matcher matcher = FACTSET_FILENAME_PATTERN_COMPILED.matcher(filenameWithoutExt);

        if (!matcher.matches()) {
            log.warn("Response filename '{}' does not match expected {} pattern,"
                + " skipping diffusion", responseFilename, FACTSET);
            return;
        }

        char clientLetter = matcher.group(1).charAt(0);
        String instrumentCode = matcher.group(2);

        Optional<String> maybeClientLabel =
            resolveOndemandActiveClient(clientLetter, responseFilename);
        if (maybeClientLabel.isEmpty()) {
            return;
        }

        String clientLabel = maybeClientLabel.get();
        String instrumentType =
            FactSetConstants.INSTRUMENT_CODE_TO_TYPE.get(instrumentCode);

        if (instrumentType == null) {
            log.error("Unknown instrument code '{}' in filename '{}',"
                + " cannot proceed with diffusion",
                instrumentCode, responseFilename);
            return;
        }

        log.info("FactSet response file '{}' extracted: client='{}', instrument='{}',"
            + " diffusedData='{}'", responseFilename, clientLabel, instrumentType,
            FactSetConstants.DIFFUSED_DATA_DERIVED);

        DiffusionCommand command = DiffusionCommand.builder()
                .clientName(clientLabel)
                .instrument(instrumentType)
                .diffusedData(FactSetConstants.DIFFUSED_DATA_DERIVED)
                .build();

        diffusionHandler.processDiffusionCommand(command);
    }

    private Optional<String> resolveOndemandActiveClient(
            char clientLetter, String responseFilename) {
        String clientLabel =
            FactSetConstants.CLIENT_LETTER_TO_LABEL.get(clientLetter);

        if (clientLabel == null) {
            log.error("Unknown client letter '{}' in filename '{}',"
                + " cannot proceed with diffusion", clientLetter, responseFilename);
            return Optional.empty();
        }

        Optional<ClientReferenceDto> maybeClient =
            clientReferenceService.getClientByClientLabel(clientLabel);

        if (maybeClient.isEmpty()) {
            log.error("Client reference not found for client label '{}',"
                + " cannot proceed with diffusion", clientLabel);
            return Optional.empty();
        }

        ClientReferenceDto client = maybeClient.get();

        if (!client.isOnDemandActive()) {
            log.info("On-demand is not active for client '{}',"
                + " skipping diffusion", clientLabel);
            return Optional.empty();
        }

        return Optional.of(clientLabel);
    }
}





// Normal (derived) FactSet response files: BP2S_DT<letter>_<code>_DD_<n>_<n>
public static final String FACTSET_FILENAME_PATTERN =
    "^BP2S_DT([A-Z])_(EQ|FI|FU|OP|UC)_DD_(\\d+)_(\\d+)$";
public static final Pattern FACTSET_FILENAME_PATTERN_COMPILED =
    Pattern.compile(FACTSET_FILENAME_PATTERN);
