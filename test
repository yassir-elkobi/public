/**
 * Extracts the client identifier from the synchronization file name using the shared regex.
 * For Historical sync files (containing _H_ in the filename), the full Historical
 * client name is returned by appending _H suffix (e.g. APE → APE_H, IRP_BV → IRP_BV_H).
 */
public String extractClient(String syncFileName) {
    Matcher matcher = ON_DEMAND_FILENAME_PATTERN.matcher(syncFileName);
    if (matcher.find()) {
        String client = matcher.group(1);
        String syncTypePart = matcher.group(2);

        // Process H: regex captures "APE" from "MUSE_Sync_DAL_APE_H_20260518_001.csv"
        // because (.*?) stops before _H_. Append _H to get the real client label APE_H.
        if ("_H_".equals(syncTypePart)) {
            client = client + "_H";
        }

        log.info("Extracted '{}' client Name for request file '{}'", client, syncFileName);
        return client;
    }
    log.info("No Client Name Found for the Expression '{}' for the request file '{}'",
            ON_DEMAND_FILENAME_REGEX, syncFileName);
    return "";
}
