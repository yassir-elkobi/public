    /**
     * Resolves a single Factset output field. Each field type owns its own resolver
     * so the dispatch reads top to bottom with no nested branching.
     */
    private void populateField(JSONObject output, Map<String, Object> itemMap, String field,
                               String identifier, ResolvedRequestParams params, String requestDate) {
        FieldKind kind = FieldKind.classify(field, params.instrumentType(), params.fundsInstrumentType());

        switch (kind) {
            case FUNDS_COMPOUND -> output.put(field, resolveFundsCompound(itemMap, identifier, params));
            case PROVIDER_COMPOUND -> output.put(field, resolveProviderCompound(itemMap, identifier, field));
            case PRICE_EXPRESSION_FIELD -> output.put(field, resolvePriceExpression(itemMap, identifier, params.priceExpression()));
            case SYNONYM_CODE_FIELD -> output.put(field, itemMap.get(identifier.toUpperCase()));
            case INSTRUMENT_TYPE_FIELD -> output.put(field, InstrumentTypeMapper.getDisplayValue((String) itemMap.get(INSTRUMENT)));
            case DATE_FIELD -> output.put(field, requestDate);
            case PLAIN -> output.put(field, itemMap.get(field.replace(' ', '_').toUpperCase()));
        }
    }

    private Object resolveFundsCompound(Map<String, Object> itemMap, String identifier,
                                        ResolvedRequestParams params) {
        Object left = itemMap.get(identifier.toUpperCase());
        String[] parts = params.instrumentType().split("\\|");
        return parts.length > 1 ? left + COMPOUND_DELIMITER + itemMap.get(parts[1].toUpperCase()) : left;
    }

    private Object resolveProviderCompound(Map<String, Object> itemMap, String identifier, String field) {
        Object left = itemMap.get(identifier.toUpperCase());
        String[] parts = field.split(COMPOUND_DELIMITER, 2);
        if (parts.length <= 1) {
            return left;
        }
        Object right = itemMap.get(normalizeKey(parts[1]));
        if (right == null) {
            log.debug("populateField: right-side key '{}' not found for field '{}'", parts[1], field);
            return left;
        }
        return left + COMPOUND_DELIMITER + right;
    }

    private Object resolvePriceExpression(Map<String, Object> itemMap, String identifier,
                                          String priceExpression) {
        if (priceExpression == null || !priceExpression.contains(COMPOUND_DELIMITER)) {
            return priceExpression;
        }
        String[] parts = priceExpression.split(COMPOUND_DELIMITER, 2);
        Object right = itemMap.get(normalizeKey(parts[1]));
        Object left = itemMap.get(identifier.toUpperCase());
        return right != null ? left + COMPOUND_DELIMITER + right : priceExpression;
    }

    private static String normalizeKey(String key) {
        return key.trim().replace(' ', '_').toUpperCase();
    }

    // ---- value objects -----------------------------------------------------

    private record ResolvedRequestParams(List<String> identifiers, String onDemandFileName,
                                         String outputFileName, String instrumentType,
                                         String priceExpression, boolean fundsInstrumentType) {
    }

    private record RequestDates(boolean isHistorical, String historicalDate, String today,
                                String requestDate) {
    }

    private enum FieldKind {
        FUNDS_COMPOUND, PROVIDER_COMPOUND, PRICE_EXPRESSION_FIELD, SYNONYM_CODE_FIELD,
        INSTRUMENT_TYPE_FIELD, DATE_FIELD, PLAIN;

        static FieldKind classify(String field, String instrumentType, boolean fundsInstrumentType) {
            if (field.contains(COMPOUND_DELIMITER)) {
                return (!instrumentType.isEmpty() && fundsInstrumentType)
                        ? FUNDS_COMPOUND : PROVIDER_COMPOUND;
            }
            if (field.equalsIgnoreCase(PRICE_EXPRESSION.replace("_", " "))) return PRICE_EXPRESSION_FIELD;
            if (field.equalsIgnoreCase(SYNONYM_CODE)) return SYNONYM_CODE_FIELD;
            if (field.equalsIgnoreCase(INSTRUMENT_TYPE)) return INSTRUMENT_TYPE_FIELD;
            if (field.equalsIgnoreCase(DATE)) return DATE_FIELD;
            return PLAIN;
        }
    }
