@Bean
@StepScope
public ItemProcessor<OnDemandScopeDetailsDto, OnDemandScopeDetailsDto> fctOnDemandFilter(
        @Value("#{jobParameters[syncType]}") String syncType,
        @Value("#{jobParameters[clientName]}") String clientName,
        @Value("#{jobParameters[startAt]}") LocalDateTime startTime,
        @Qualifier("factSetProviderFactory") ProviderStepFactory factory,   // confirm bean name
        ClientReferenceService clientReferenceService,
        ClientScopeEsRetriever clientScopeEsRetriever) {
    return buildProviderFilter(factory.filter(), syncType, clientName, startTime,
            clientReferenceService, clientScopeEsRetriever, new FctScopeMatchStrategy());
}

