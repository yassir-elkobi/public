@Override
public String resolveHistoricalDate(String fileName) {
    return extractHistoricalDateForResponse(fileName);
}

@Override
public Map<String, List<JSONObject>> enrichProcessedItem(JSONObject entry,
        Map<String, List<JSONObject>> indexDocumentsMap,
        Map<String, String> charsetConversionValue,
        String fileName, long integrationId, String historicalDate) {
    try {
        dataIndexMapping.forEach(dto ->
                indexDocumentsMap
                        .computeIfAbsent(dto.getIndexName(), k -> new ArrayList<>())
                        .add(entry));

        // Stamp PROVIDER_DATATYPE and HISTORICAL_DATE on every document.
        // historicalDate is pre-resolved once per file (null for non-historical).
        dataIndexMapping.forEach(dto ->
                indexDocumentsMap.getOrDefault(dto.getIndexName(), List.of())
                        .forEach(json -> {
                            json.put(PROVIDER_DATATYPE, dto.getDataType());
                            if (historicalDate != null) {
                                json.put(HISTORICAL_DATE, historicalDate);
                            }
                        }));
    } catch (Exception e) {
        log.error(ErrorConstants.ENRICHING_PROCESSED_ITEM_FAILED, e);
        fileIntegrationStatusUpdater.updateStatus(INTEGRATION_FAILED, integrationId);
    }
    return indexDocumentsMap;
}

// extractHistoricalDateForResponse stays the same — now called only once via resolveHistoricalDate
private String extractHistoricalDateForResponse(String responseFileName) {
    try {
        Optional<RequestDetailsDto> request = requestDetailsService.getLastByResponseFilename(responseFileName);
        if (request.isEmpty() || request.get().getRequestFilename() == null) {
            return null;
        }
        Matcher matcher = HISTORICAL_DATE_PATTERN.matcher(request.get().getRequestFilename());
        return matcher.find() ? matcher.group(1) : null;
    } catch (Exception e) {
        log.warn("Could not extract historical date for response '{}'; storing without HISTORICAL_DATE",
                responseFileName, e);
        return null;
    }
}



