private static final DateTimeFormatter REQUEST_DATE_FORMAT = DateTimeFormatter.ofPattern("yyyyMMdd");
private static final DateTimeFormatter DERIVED_INDEX_DATE_FORMAT = DateTimeFormatter.ofPattern("dd/MM/yyyy");

@Override
public boolean hasDerivedDataFor(String securityId, String marketPlace, String historicalDate) {
    if (isAnyArgumentMissing(securityId, marketPlace, historicalDate)) {
        return false;
    }
    try {
        BoolQuery query = buildExistenceQuery(securityId, marketPlace, historicalDate);
        long count = elasticsearchService.countForBoolQuery(query, DERIVED_INDEX_NAME);
        return count > 0;
    } catch (Exception e) {
        log.error("Existence check failed for security={}, market={}, date={} - failing open",
                securityId, marketPlace, historicalDate, e);
        return false;
    }
}

private BoolQuery buildExistenceQuery(String securityId, String marketPlace, String historicalDate) {
    String isinMarketKey = securityId + "_" + marketPlace;
    String derivedDate = toDerivedIndexDateFormat(historicalDate.trim());
    return QueryBuilders.bool()
            .must(m -> m.matchPhrase(mp -> mp.field(ISIN_MARKET).query(isinMarketKey)))
            .must(m -> m.matchPhrase(mp -> mp.field(HISTORICAL_DATE).query(derivedDate)))
            .build();
}

/**
 * The sync request delivers the historical date as YYYYMMDD (e.g. 20260430),
 * but the derived index stores "HISTORICAL DATE" as dd/MM/yyyy (e.g. 30/04/2026).
 * Convert before querying so the existence check matches.
 */
private String toDerivedIndexDateFormat(String yyyyMmDd) {
    try {
        return LocalDate.parse(yyyyMmDd, REQUEST_DATE_FORMAT).format(DERIVED_INDEX_DATE_FORMAT);
    } catch (DateTimeParseException e) {
        log.warn("Historical date '{}' not in YYYYMMDD; querying derived index as-is", yyyyMmDd);
        return yyyyMmDd;
    }
}















