String onDemandFileName = dates.isHistorical() && !params.onDemandFileName().isEmpty()
        ? toHistoricalFileName(params.onDemandFileName(), dates)
        : params.onDemandFileName();



/**
 * Historical request filename: DD_INPUT_<CLIENT>_H_<date>.req
 * getOnDemandFileName then appends the unique id → DD_INPUT_APEM_H_20260603-<uid>.req
 * Normal derived files do not get a date inserted (handled by the caller, not this method).
 */
private String toHistoricalFileName(String onDemandFileName, RequestDatesContext dates) {
    int dotIdx = onDemandFileName.lastIndexOf('.');
    String base = (dotIdx > 0) ? onDemandFileName.substring(0, dotIdx) : onDemandFileName;
    String ext  = (dotIdx > 0) ? onDemandFileName.substring(dotIdx) : DEFAULT_REQUEST_EXTENSION;

    String fileDate = dates.requestDate(); // historical date for H flow, already YYYYMMDD

    String historicalBase;
    if (base.endsWith("_U") || base.endsWith("_I")) {
        historicalBase = base.substring(0, base.length() - 2) + "_H_" + fileDate;
    } else if (base.endsWith("_H")) {
        historicalBase = base + "_" + fileDate;
    } else {
        historicalBase = base + "_H_" + fileDate;
    }
    return historicalBase + ext;
}




@Override
public boolean hasDerivedDataFor(String securityId, String marketPlace, String historicalDate) {
    if (isAnyArgumentMissing(securityId, marketPlace, historicalDate)) {
        return false;
    }
    try {
        BoolQuery query = buildExistenceQuery(securityId, marketPlace, historicalDate);
        long count = elasticsearchService.countForBoolQuery(query, DERIVED_INDEX_NAME);
        return count > 0;
    } catch (Exception e) {
        log.error("Existence check failed for security={}, market={}, date={} - failing open",
                securityId, marketPlace, historicalDate, e);
        return false;
    }
}

private BoolQuery buildExistenceQuery(String securityId, String marketPlace, String historicalDate) {
    String isinMarketKey = securityId + "_" + marketPlace;
    String trimmedDate = historicalDate.trim();
    return QueryBuilders.bool()
            .must(m -> m.matchPhrase(mp -> mp.field(ISIN_MARKET).query(isinMarketKey)))
            .must(m -> m.matchPhrase(mp -> mp.field(HISTORICAL_DATE).query(trimmedDate)))
            .build();
}






