private void diffuseDerived(FileIntegrationDetailsDto responseIntegratedFile) {
    String responseFilename = responseIntegratedFile.getFilename();

    String filenameWithoutExt = getFileNameWithoutExtension(responseFilename);
    Matcher matcher = FACTSET_FILENAME_PATTERN_COMPILED.matcher(filenameWithoutExt);

    if (!matcher.matches()) {
        log.warn("Response filename '{}' does not match expected {} pattern,"
            + " skipping diffusion", responseFilename, FACTSET);
        return;
    }

    char clientLetter = matcher.group(1).charAt(0);
    String instrumentCode = matcher.group(2);

    Optional<String> maybeClientLabel =
        resolveOndemandActiveClient(clientLetter, responseFilename);
    if (maybeClientLabel.isEmpty()) {
        return;
    }

    String clientLabel = maybeClientLabel.get();
    String instrumentType =
        FactSetConstants.INSTRUMENT_CODE_TO_TYPE.get(instrumentCode);

    if (instrumentType == null) {
        log.error("Unknown instrument code '{}' in filename '{}',"
            + " cannot proceed with diffusion",
            instrumentCode, responseFilename);
        return;
    }

    log.info("FactSet response file '{}' extracted: client='{}', instrument='{}',"
        + " diffusedData='{}'", responseFilename, clientLabel, instrumentType,
        FactSetConstants.DIFFUSED_DATA_DERIVED);

    DiffusionCommand command = DiffusionCommand.builder()
            .clientName(clientLabel)
            .instrument(instrumentType)
            .diffusedData(FactSetConstants.DIFFUSED_DATA_DERIVED)
            .build();

    diffusionHandler.processDiffusionCommand(command);
}





// Normal (derived) FactSet response files: BP2S_DT<letter>_<code>_DD_<n>_<n>
public static final String FACTSET_FILENAME_PATTERN =
    "^BP2S_DT([A-Z])_(EQ|FI|FU|OP|UC)_DD_(\\d+)_(\\d+)$";
public static final Pattern FACTSET_FILENAME_PATTERN_COMPILED =
    Pattern.compile(FACTSET_FILENAME_PATTERN);
