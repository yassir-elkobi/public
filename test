public static BoolQuery buildScopeQuery(ClientScopeContext context) {
    Query clientMatch = MatchQuery.of(m -> m.field(CLIENT_KEYWORD).query(context.clientName()))._toQuery();
    Query syncFileMatch = MatchQuery.of(m -> m.field(SYNC_FILE_KEYWORD)
            .query(StringUtils.isBlank(context.syncFileName())
                    ? ABSENT_SYNC_FILENAME_QUERY_VALUE : context.syncFileName()))._toQuery();

    BoolQuery.Builder scopeQueryBuilder = new BoolQuery.Builder()
            .must(clientMatch)
            .should(syncFileMatch);

    // Historical clients have a null initSynchroTime; only add the range filter
    // when a sync time is present.
    if (context.initSynchroTime() != null) {
        Query rangeQuery = RangeQuery.of(r -> r.date(d -> d
                .field(TIMESTAMP_FIELD)
                .gte(context.initSynchroTime().format(YYYY_MM_DD_HH_MM_SS_FORMATTER))))._toQuery();
        scopeQueryBuilder.filter(rangeQuery);
    }

    if (!PRICES_INDEX.getIndexParam().equals(context.instrument())) {
        Query instrumentMatch = MatchQuery.of(m -> m.field(INSTRUMENT_KEYWORD)
                .query(context.instrument()))._toQuery();
        scopeQueryBuilder.must(instrumentMatch);
    }

    return scopeQueryBuilder.build();
}




private static Query buildIdentifierClause(JSONObject securityItem, String providerIdentifierField,
                                           List<String> clientIdentifierFields) {
    BoolQuery.Builder identifierClause;
    if (clientIdentifierFields.size() == 1) {
        identifierClause = QueryBuilders.bool()
                .must(matchPhrase(providerIdentifierField,
                        (String) securityItem.get(clientIdentifierFields.get(0))));
    } else {
        identifierClause = QueryBuilders.bool()
                .should(matchPhrase(providerIdentifierField,
                        (String) securityItem.get(clientIdentifierFields.get(0))));
        for (int i = 1; i < clientIdentifierFields.size(); i++) {
            String clientIdField = clientIdentifierFields.get(i);
            if (nonNull(securityItem.get(clientIdField))
                    && isNotBlank(securityItem.get(clientIdField).toString())) {
                identifierClause.should(matchPhrase(providerIdentifierField,
                        (String) securityItem.get(clientIdField)));
            }
        }
    }
    return identifierClause.build()._toQuery();
}





