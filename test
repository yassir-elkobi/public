@Log4j2
@Service
@RequiredArgsConstructor
public class OnDemandFeedDetailsRetriever {

    private final OnDemandRequestService onDemandRequestService;
    private final InstrumentReferenceService instrumentReferenceService;
    private final RequestParamService requestParamService;
    private final ClientReferenceService clientReferenceService;  // ADD this dependency

    public List<OnDemandScopeDetailsDto> getVacationDetails(
            List<JSONObject> jsonObjectsOfScope, String syncFileName) {

        List<OnDemandScopeDetailsDto> dtoList = new ArrayList<>();

        Map<Integer, String> onDemandVacationNamesById = onDemandRequestService.getOnDemandVacationNamesById();
        Map<String, List<Map<String, Integer>>> feedInstrList = getInstrSubInstMappingsByVacationName(onDemandVacationNamesById, syncFileName);
        Map<String, JSONArray> headerParams = getHeaderParamsForVacation(onDemandVacationNamesById, syncFileName);
        Map<String, List<String>> fieldListByVacationName = getFieldListForVacation(onDemandVacationNamesById);
        Map<String, Map<String, String>> vacConfigDetailsByVacName = getVacConfigDetailsByVacName(onDemandVacationNamesById);
        Map<Long, String> instrumentCodesByInstrumentId = instrumentReferenceService.getAllValidInstrumentCodeByInstrumentId();

        // Cache per-client params to avoid repeated DB queries when scope has many securities for the same client
        Map<String, List<RequestParametersDto>> paramsByClient = new HashMap<>();

        for (JSONObject jsonObj : jsonObjectsOfScope) {
            List<String> providerName = new ArrayList<>();
            if ("Y".equals(jsonObj.get(STATIC_FLAG)) || "Y".equals(jsonObj.get(PRICE_FLAG))) {
                providerName.add(BLOOMBERG);
            }
            if ("Y".equals(jsonObj.get(DERIVED_FLAG))) {
                providerName.add(FACTSET);
            }

            // Filter request parameters to those for this security's client
            // (plus generic rows where client_reference_id is null).
            String securityClient = (String) jsonObj.get(CLIENT);
            List<RequestParametersDto> clientParams = paramsByClient.computeIfAbsent(
                    securityClient, this::loadParamsForClient);

            OnDemandScopeDetailsDto onDemandScopeDetailsDto = OnDemandScopeDetailsDto.builder()
                    .headerParams(headerParams)
                    .fieldListByVacationName(fieldListByVacationName)
                    .feedInstrList(feedInstrList)
                    .instrumentCodesByInstrumentId(instrumentCodesByInstrumentId)
                    .vacConfigDetailsByVacName(vacConfigDetailsByVacName)
                    .item(jsonObj)
                    .onDemandVacationNamesById(onDemandVacationNamesById)
                    .requestParametersDtos(clientParams)
                    .providerName(providerName)
                    .build();
            dtoList.add(onDemandScopeDetailsDto);
        }
        return dtoList;
    }

    /**
     * Loads request parameters scoped to the given client.
     * Returns rows matching the client plus generic rows (where client_reference_id is null).
     * Falls back to all rows if the client cannot be resolved.
     */
    private List<RequestParametersDto> loadParamsForClient(String clientName) {
        if (clientName == null || clientName.isBlank()) {
            return requestParamService.findAll();
        }
        ClientReferenceDto clientRef = clientReferenceService.getForClientName(clientName);
        if (clientRef == null) {
            log.warn("No client reference found for '{}' — falling back to all request parameters", clientName);
            return requestParamService.findAll();
        }
        return requestParamService.findByClientReferenceIdOrGeneric(clientRef.getId());
    }

