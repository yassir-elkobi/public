

@Test
void rewritesFilenameToHistoricalPatternWhenHistoricalDatePresent() throws Exception {
    OnDemandScopeDetailsDto item = buildHistoricalScopeItem(
            "FR0000120644", "PAR", "20260504",
            "DD_INPUT_APEM_U.req", "BP2S_APEM_OUT.out");

    List<JSONObject> outputs = demandHandler.generateOutputResult(item);

    assertThat(outputs).isNotEmpty();
    JSONObject first = outputs.get(0);
    
    // Filename uses TODAY's date (when request is generated).
    // Historical date is stored inside the file content (Date column).
    String today = LocalDate.now().format(DateTimeFormatter.ofPattern("yyyyMMdd"));
    assertThat((String) first.get(ON_DEMAND_FILENAME))
            .isEqualTo("DD_INPUT_APEM_H_" + today + ".req");
    
    // HISTORICAL_DATE field remains the original historical date for tracking
    assertThat(first.get(HISTORICAL_DATE)).isEqualTo("20260504");
}
